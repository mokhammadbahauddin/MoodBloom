{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "gender": { "type": "string", "enum": ["male", "female", "other"] },
        "avatarUrl": { "type": "string" },
        "role": { "type": "string" },
        "points": { "type": "number" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["email", "createdAt", "updatedAt"]
    },
    "Product": {
      "title": "Product",
      "description": "Product details",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "originalPrice": { "type": "number" },
        "imageUrl": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "category": { "type": "string" },
        "rating": { "type": "number" },
        "reviewsCount": { "type": "number" },
        "soldCount": { "type": "number" },
        "storeName": { "type": "string" },
        "isOfficialStore": { "type": "boolean" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["name", "price", "createdAt", "updatedAt"]
    },
    "CartItem": {
      "title": "CartItem",
      "description": "Item in a user's cart",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "quantity": { "type": "number" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["productId", "quantity", "createdAt", "updatedAt"]
    },
    "Order": {
      "title": "Order",
      "description": "User order",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "subtotal": { "type": "number" },
        "shippingFee": { "type": "number" },
        "discount": { "type": "number" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered"] },
        "paymentMethod": { "type": "string" },
        "shippingAddress": { "type": "object" },
        "estimatedDelivery": { "type": "string" },
        "courier": { "type": "string" },
        "trackingNumber": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["userId", "items", "totalAmount", "status", "createdAt", "updatedAt"]
    },
    "Voucher": {
      "title": "Voucher",
      "description": "Available vouchers",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "discountType": { "type": "string", "enum": ["percentage", "fixed"] },
        "discountValue": { "type": "number" },
        "minSpend": { "type": "number" },
        "maxDiscount": { "type": "number" },
        "validUntil": { "type": "string" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string" }
      },
      "required": ["code", "title", "discountType", "discountValue", "isActive", "createdAt"]
    },
    "Wishlist": {
      "title": "Wishlist",
      "description": "User's saved products",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "productId": { "type": "string" },
        "product": { "type": "object" },
        "addedAt": { "type": "string" }
      },
      "required": ["userId", "productId", "addedAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User notifications",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "body": { "type": "string" },
        "type": { "type": "string" },
        "isRead": { "type": "boolean" },
        "metadata": { "type": "object" },
        "createdAt": { "type": "string" }
      },
      "required": ["title", "body", "type", "isRead", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Products catalog"
    },
    "carts/{userId}/items/{itemId}": {
      "schema": { "$ref": "#/entities/CartItem" },
      "description": "Items in user's cart"
    },
    "orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "User purchases"
    },
    "vouchers/{voucherId}": {
      "schema": { "$ref": "#/entities/Voucher" },
      "description": "Available discount codes"
    },
    "wishlist/{wishlistId}": {
      "schema": { "$ref": "#/entities/Wishlist" },
      "description": "User's wishlist items"
    },
    "users/{userId}/notifications/{notificationId}": {
      "schema": { "$ref": "#/entities/Notification" },
      "description": "User notifications"
    }
  }
}
